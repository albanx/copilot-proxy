{
  "name": "copilot-bridge",
  "version": "1.1.0",
  "description": "Turn GitHub Copilot into OpenAI/Anthropic API compatible server. Usable with Claude Code!",
  "keywords": [
    "proxy",
    "github-copilot",
    "openai-compatible"
  ],
  "homepage": "https://github.com/albanx/copilot-proxy",
  "bugs": "https://github.com/albanx/copilot-proxy/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/albanx/copilot-proxy.git"
  },
  "type": "module",
  "bin": {
    "copilot-bridge": "./dist/main.js",
    "copx": "./dist/main.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "bun run --watch ./src/main.ts",
    "knip": "knip-bun",
    "lint": "eslint --cache",
    "lint:all": "eslint --cache .",
    "prepack": "bun run build",
    "prepare": "simple-git-hooks",
    "release": "bumpp && bun publish",
    "start": "NODE_ENV=production bun run ./src/main.ts",
    "typecheck": "tsc"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx lint-staged"
  },
  "lint-staged": {
    "*": "bun run lint --fix"
  },
  "dependencies": {
    "citty": "^0.1.6",
    "clipboardy": "^5.0.0",
    "consola": "^3.4.2",
    "fetch-event-stream": "^0.1.5",
    "gpt-tokenizer": "^3.0.1",
    "hono": "^4.9.9",
    "proxy-from-env": "^1.1.0",
    "srvx": "^0.8.9",
    "tiny-invariant": "^1.3.3",
    "undici": "^7.16.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.2.23",
    "@types/proxy-from-env": "^1.0.4",
    "bumpp": "^10.2.3",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "knip": "^5.64.1",
    "lint-staged": "^16.2.3",
    "prettier": "^3.8.3",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "^0.15.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0",
    "zod": "^4.1.12"
  }
}
